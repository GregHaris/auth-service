{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "lib": [
      "esnext"
    ],
    "types": [
      "node"
    ],
    "typeRoots": [
      "./node_modules/@types"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@auth-service/types": [
        "../../packages/types/src/index.ts"
      ],
      "@auth-service/types/*": [
        "../../packages/types/src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "prisma/**/*.ts",
    "*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}