{
  "compilerOptions": {
    "target": "ES2020",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@packages/*": ["packages/*"]
    }
  },
  "include": [
    "modules/**/*.ts",
    "lib/**/*.ts",
    "types/**/*.ts",
    "types/**/*.d.ts",
    "index.ts",
    "apps/api/**/*.ts",
    "apps/web/**/*.tsx"
  ]
}
